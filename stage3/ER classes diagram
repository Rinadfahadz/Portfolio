erDiagram

USER {
  int user_id
  string name
  string skills
  int participations
  int wins
}

TEAM {
  int team_id
  string name
  string idea
  int owner_id
  int hackathon_id
}

HACKATHON {
  int hackathon_id
  string name
  string description
}

REQUEST {
  int request_id
  int sender_id
  int receiver_user_id
  int receiver_team_id
  string type
  string status
  datetime created_at
}

CHATROOM {
  int chat_id
  datetime created_at
}

MESSAGE {
  int message_id
  int chat_id
  int sender_id
  string content
  datetime timestamp
}

RATING {
  int rating_id
  int rater_id
  int rated_user_id
  int value
  string comment
  datetime created_at
}

TEAM_MEMBER {
  int user_id
  int team_id
}

CHAT_PARTICIPANT {
  int chat_id
  int user_id
}

%% =====================
%% Relationships
%% =====================

USER ||--o{ TEAM : owns
HACKATHON ||--o{ TEAM : contains

USER ||--o{ REQUEST : sends
USER ||--o{ REQUEST : receives
TEAM ||--o{ REQUEST : receives

CHATROOM ||--o{ MESSAGE : contains
USER ||--o{ MESSAGE : sends

USER ||--o{ RATING : gives
USER ||--o{ RATING : receives

USER ||--o{ TEAM_MEMBER : joins
TEAM ||--o{ TEAM_MEMBER : has

CHATROOM ||--o{ CHAT_PARTICIPANT : has
USER ||--o{ CHAT_PARTICIPANT : joins

